      <!-- Right doorway - Bottom horizontal lintel -->
      <link name='Wall_43'>
        <pose frame=''>5.36 -0.515 0 0 -0 0</pose>
        <collision name='Wall_43_Collision'>
          <geometry>
            <box>
              <size>0.5 0.15 0.5</size>
            </box>
          </geometry>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
        </collision>
        <visual name='Wall_43_Visual'>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
          <geometry>
