      <link name='Wall_10'>
        <pose frame=''>-5.055 1.375 0 0 -0 -1.5708</pose>
        <collision name='Wall_10_Collision'>
          <geometry>
            <box>
              <size>2.25 0.15 0.5</size>
            </box>
          </geometry>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
        </collision>
        <visual name='Wall_10_Visual'>
