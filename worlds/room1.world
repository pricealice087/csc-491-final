      <!-- Right doorway - Top horizontal lintel (above door opening) -->
      <link name='Wall_49'>
        <pose frame=''>5.35 0.315 0 0 -0 0</pose>
        <collision name='Wall_49_Collision'>
          <geometry>
            <box>
              <size>0.5 0.15 0.5</size>
            </box>
          </geometry>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
