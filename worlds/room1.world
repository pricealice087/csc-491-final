      <!-- Left doorway - North wall extension to outer wall -->
      <link name='Wall_19'>
        <pose frame=''>-5.055 -1.45 0 0 -0 -1.5708</pose>
        <collision name='Wall_19_Collision'>
          <geometry>
            <box>
              <size>2 0.15 0.5</size>
