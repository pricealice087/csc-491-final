    </model> <!-- End of exp_empty_rooms -->

    <!-- ============================================================ -->
    <!-- BASKETBALL - TARGET OBJECT FOR DELIVERY ROBOT -->
    <!-- Position: Center of the world at origin -->
    <!-- This is what the robot needs to find and deliver! -->
    <!-- ============================================================ -->
    <model name='basketball'>
      <pose frame=''>-10 0 0 0 0 0</pose> <!-- x, y, z position (z=radius so ball sits on ground) -->
      <link name='link'>
        <!-- Physical properties of basketball -->
        <inertial>
          <mass>0.624</mass> <!-- NBA regulation basketball: 624 grams -->
          <inertia>
            <ixx>0.001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.001</iyy>
            <iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        
        <!-- Collision geometry -->
        <collision name='collision'>
          <geometry>
            <sphere>
              <radius>0.12</radius> <!-- Basketball radius: 12cm (standard size) -->
            </sphere>
          </geometry>
          <surface>
            <bounce>
              <restitution_coefficient>0.8</restitution_coefficient> <!-- Makes it bouncy! -->
            </bounce>
            <friction>
              <ode>
                <mu>1.0</mu>   <!-- Surface friction -->
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        
        <!-- Visual appearance -->
        <visual name='visual'>
          <geometry>
            <sphere>
              <radius>0.12</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>1 0.5 0 1</ambient>  <!-- Orange color (R=1, G=0.5, B=0, A=1) -->
            <diffuse>1 0.5 0 1</diffuse>  <!-- Diffuse reflection -->
            <specular>0.1 0.1 0.1 1</specular> <!-- Slight shininess -->
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- PHYSICS & ENVIRONMENT SETTINGS -->
    <!-- ============================================================ -->
    
    <!-- Gravity -->
    <gravity>0 0 -9.8</gravity>
    
    <!-- Magnetic field (Earth-like) -->
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    
    <!-- Atmosphere -->
    <atmosphere type='adiabatic'/>
    
    <!-- Physics engine settings -->
    <physics name='default_physics' default='0' type='ode'>
      <max_step_size>0.001</max_step_size>        <!-- 1ms time steps -->
      <real_time_factor>1</real_time_factor>      <!-- Run at real-time speed -->
      <real_time_update_rate>1000</real_time_update_rate> <!-- 1000 Hz update rate -->
    </physics>
    
    <!-- Scene lighting and appearance -->
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>     <!-- Ambient light level -->
      <background>0.7 0.7 0.7 1</background> <!-- Gray background -->
      <shadows>1</shadows>                 <!-- Enable shadows -->
    </scene>

  </world>
</sdf>
