<?xml version="1.0"?>
<sdf version='1.6'>
  <world name='default'>
    
    <!-- ============================================================ -->
    <!-- LIGHTING - Directional sun for realistic shadows -->
    <!-- ============================================================ -->
    <light name='sun' type='directional'>
      <cast_shadows>1</cast_shadows>
      <pose frame=''>0 0 10 0 -0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ============================================================ -->
    <!-- GROUND PLANE - Flat surface for the robot to drive on -->
    <!-- ============================================================ -->
    <model name='ground_plane'>
      <static>1</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>   <!-- High friction - robot won't slip -->
                <mu2>50</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='visual'>
          <cast_shadows>0</cast_shadows>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- ROOM STRUCTURE - Multi-room layout with doorways -->
    <!-- Layout: Left room | Center hallway | Right room -->
    <!-- Total dimensions: ~30m x ~5m -->
    <!-- ============================================================ -->
    <model name='exp_empty_rooms'>
      <static>1</static> <!-- Walls don't move -->
      
      <!-- ==================== OUTER PERIMETER WALLS ==================== -->
      
      <!-- WEST WALL (Left side, 5m long) -->
      <link name='Wall_0'>
        <pose frame=''>-14.925 0 0 0 -0 -1.5708</pose>
        <collision name='Wall_0_Collision'>
          <geometry>
            <box>
              <size>5 0.15 0.5</size> <!-- length, thickness, height -->
            </box>
          </geometry>
          <pose frame=''>0 0 0.25 0 -0 0</pose> <!-- Raised to sit on ground -->
        </collision>
        <visual name='Wall_0_Visual'>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
          <geometry>
            <box>
              <size>5 0.15 0.5</size>
            </box>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
            <ambient>1 1 1 1</ambient>
          </material>
        </visual>
      </link>

      <!-- SOUTH WALL (Bottom, 30m long) -->
      <link name='Wall_1'>
        <pose frame=''>0 -2.425 0 0 -0 0</pose>
        <collision name='Wall_1_Collision'>
          <geometry>
            <box>
              <size>30 0.15 0.5</size>
            </box>
          </geometry>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
        </collision>
        <visual name='Wall_1_Visual'>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
          <geometry>
            <box>
              <size>30 0.15 0.5</size>
            </box>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
            <ambient>1 1 1 1</ambient>
          </material>
        </visual>
      </link>

      <!-- EAST WALL (Right side, 5m long) -->
      <link name='Wall_2'>
        <pose frame=''>14.925 0 0 0 -0 1.5708</pose>
        <collision name='Wall_2_Collision'>
          <geometry>
            <box>
              <size>5 0.15 0.5</size>
            </box>
          </geometry>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
