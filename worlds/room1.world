      <!-- ==================== RIGHT DOORWAY SEGMENTS ==================== -->
      <!-- Creates a door opening between center hallway and right room -->
      
      <!-- Right doorway - South wall segment -->
      <link name='Wall_38'>
        <pose frame=''>5.185 -1.44 0 0 -0 -1.5708</pose>
        <collision name='Wall_38_Collision'>
          <geometry>
            <box>
              <size>2 0.15 0.5</size>
            </box>
          </geometry>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
        </collision>
        <visual name='Wall_38_Visual'>
          <pose frame=''>0 0 0.25 0 -0 0</pose>
